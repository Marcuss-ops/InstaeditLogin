# ops/local/Caddyfile — committed, repo-friendly version of the local
# Caddyfile used by the Docker + Caddy + SSH-tunnel development stack
# documented in `docs/LOCAL-DEVELOPMENT.md`.
#
# RUNTIME USAGE (operator runs on their dev VM):
#    mkdir -p ~/instaedit-certs
#    cp ops/local/Caddyfile ~/Caddyfile
#
#    docker run -d \
#      --name instaedit-caddy \
#      --restart unless-stopped \
#      --network host \
#      -v ~/Caddyfile:/etc/caddy/Caddyfile:ro \
#      -v ~/instaedit-certs:/certs:ro \
#      caddy:2
#
# Once the certs in ~/instaedit-certs/ come from `mkcert` on the operator's
# machine (scp'd here), Chrome trusts the localhost:8443 origin and the
# browser can hit Vite (via this Caddy) at the same single-origin as the
# Go API — cookies stay host-only, SessionStorage + refresh cookies work.

{
    admin off
    auto_https off
}

# `handle` (not `handle_path`) so Go's router sees the FULL path
# including `/api` — the API mounts under `/api/v1/...` and a stripped
# prefix would 404 every request.
#
# Hostname-less site block (`https://:8443`) on purpose: when reached
# directly from a browser, the Host header is `localhost`; when reached
# via `cloudflared --url https://localhost:8443`, cloudflared forwards
# the public `Host` (e.g. `village-laura-…trycloudflare.com`). Pinning
# the block to `https://localhost:8443` would produce a 0-byte response
# for the cloudflared path because Caddy would not match the site. Any
# Host header is acceptable here because this single-origin proxy is
# only used in development with both Vite and Go on the same machine.
#
# The mkcert cert SAN is only `localhost`. The cloudflared→Caddy hop
# skips cert validation via `--no-tls-verify`, so the SAN mismatch on
# the public Host is harmless. Direct browser access to the tunnel
# URL+port will warn — use the cloudflared leg or stay on localhost.
https://:8443 {
    tls /certs/localhost.pem /certs/localhost-key.pem

    handle /api/* {
        reverse_proxy 127.0.0.1:8080
    }

    # Dev S3 proxy: path-style presigned uploads land at
    # /{bucket}/{key} (bucket = instaedit-dev). Caddy forwards to the
    # host-published MinIO port; the original Host is preserved so the
    # SigV4 `host` header MinIO validates matches the signed URL.
    handle /instaedit-dev/* {
        reverse_proxy 127.0.0.1:19000 {
            header_up Host {host}
        }
    }

    handle {
        reverse_proxy 127.0.0.1:5173
    }
}
