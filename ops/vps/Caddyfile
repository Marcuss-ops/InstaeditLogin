# Public VPS reverse proxy for dev.instaedit.org.
# Requires DNS A dev.instaedit.org -> this VPS and TCP ports 80/443 open.

dev.instaedit.org {
    encode gzip
    log

    # Never expose internal Velox routes through the public proxy.
    handle /internal/* {
        abort
    }

    # Keep /api intact: the Go router mounts at /api/v1/....
    handle /api/* {
        reverse_proxy 127.0.0.1:8080
    }

    # Path-style presigned S3 URLs generated by the local API.
    handle /instaedit-local/* {
        reverse_proxy 127.0.0.1:19000 {
            header_up Host {host}
        }
    }

    # React SPA with client-side route fallback.
    handle {
        root * /srv/instaedit/web/dist
        try_files {path} /index.html
        file_server
    }
}
