# ops/vps/Caddyfile — Caddy configuration for the public VPS deployment of
# InstaEdit at dev.instaedit.org.
#
# What this does:
#   • Terminates TLS automatically with Let's Encrypt (or ZeroSSL).
#   • Proxies every request under /api/* to the Go API on 127.0.0.1:8080.
#   • Serves the compiled React SPA from /srv/instaedit/web/dist.
#   • Falls back to index.html for unknown paths so client-side routing works.
#
# Requirements before this block works:
#   1. DNS record A dev.instaedit.org → VPS public IP.
#   2. Ports 80 (HTTP) and 443 (HTTPS) open on the VPS firewall.
#   3. The Go API is listening on 127.0.0.1:8080.
#   4. The frontend has been built and copied to /srv/instaedit/web/dist.
#
# Run with Docker (recommended):
#   docker run -d \
#     --name instaedit-caddy \
#     --restart unless-stopped \
#     --network host \
#     -v /home/pierone/Projects/company/InstaeditLogin/ops/vps/Caddyfile:/etc/caddy/Caddyfile:ro \
#     -v /srv/instaedit/web/dist:/srv/instaedit/web/dist:ro \
#     -v caddy_data:/data \
#     -v caddy_config:/config \
#     caddy:2
#
# Or with systemd (after `apt install caddy`):
#   sudo cp ops/vps/Caddyfile /etc/caddy/Caddyfile
#   sudo systemctl reload caddy

dev.instaedit.org {
    encode gzip
    log

    # Velox internal endpoints (service-to-service only). These
    # routes are NOT supposed to resolve on the public hostname;
    # the InstaEdit API guards them with the VELOX_API_TOKEN
    # constant-time Bearer check, and the Velox master reaches them
    # over the in-cluster `media-backend` docker network (see
    # docker-compose.yml) — never over the public Internet. The
    # explicit `abort` here is a belt-and-braces defence: even if
    # the reverse proxy is ever misconfigured to forward `/internal/*`
    # by accident, the connection is closed without returning body
    # or status (an HTTP scanner sees nothing useful to fingerprint).
    # Listed FIRST so the matcher wins before the API/SPA catch-all.
    handle /internal/* {
        abort
    }

    handle /api/* {
        reverse_proxy 127.0.0.1:8080 {
            header_up Host {host}
        }
    }

    # Dev S3 proxy: path-style presigned uploads land at
    # /{bucket}/{key} (bucket = instaedit-dev). Caddy forwards to the
    # host-published MinIO port; the original Host is preserved so the
    # SigV4 `host` header MinIO validates matches the signed URL.
    handle /instaedit-dev/* {
        reverse_proxy 127.0.0.1:19000 {
            header_up Host {host}
        }
    }

    handle {
        root * /srv/instaedit/web/dist
        try_files {path} /index.html
        file_server
    }
}
