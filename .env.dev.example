# InstaEditLogin — Development Environment
# Copy to .env.dev and fill in real secrets.

APP_ENV=dev
LOG_LEVEL=debug

# Server
# Server listens on PORT (Vercel / Railway / Render standard). SERVER_PORT
# was removed in Taglio 5b — the api + worker targets bind PORT directly.
# Set to 8080 for the local Docker stack; Caddy reverse-proxies :8443 -> :8080.
PORT=8080
SERVER_HOST=0.0.0.0
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173

# Database (local Postgres via docker-compose)
DATABASE_URL=postgresql://instaedit:dev_password@db:5432/instaedit_login?sslmode=disable
# Alternative individual params:
# DB_HOST=db
# DB_PORT=5432
# DB_USER=instaedit
# DB_PASSWORD=dev_password
# DB_NAME=instaedit_login
# DB_SSLMODE=disable

# Meta (mandatory)
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here_at_least_32_chars
META_REDIRECT_URI=http://localhost:8080/api/v1/auth/meta/callback

# Optional OAuth providers — leave both empty to disable the platform
#TIKTOK_CLIENT_KEY=
#TIKTOK_CLIENT_SECRET=
#TIKTOK_REDIRECT_URI=http://localhost:8080/api/v1/auth/tiktok/callback

#TWITTER_CLIENT_ID=
#TWITTER_CLIENT_SECRET=
#TWITTER_REDIRECT_URI=http://localhost:8080/api/v1/auth/twitter/callback

#YOUTUBE_CLIENT_ID=
#YOUTUBE_CLIENT_SECRET=
#YOUTUBE_REDIRECT_URI=http://localhost:8080/api/v1/auth/youtube/callback

#LINKEDIN_CLIENT_ID=
#LINKEDIN_CLIENT_SECRET=
#LINKEDIN_REDIRECT_URI=http://localhost:8080/api/v1/auth/linkedin/callback

# Security
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your_base64_encoded_32_byte_key_here
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here_at_least_32_bytes
JWT_TTL_HOURS=168
STRICT_JWT_AUTH=true

# Storage (S3-compatible — MinIO in dev, Tigris / R2 / AWS in prod)
# The api + worker both require these six values to be set at boot
# (internal/bootstrap/app.go refuses to start otherwise). S3_PATH_STYLE
# MUST be true for MinIO; flip to false when targeting AWS S3 / Tigris
# virtual-hosted-style buckets.
#
# The dev stack (docker-compose.local.yml) creates a MinIO container
# + a one-shot minio-init container that runs `mc mb --ignore-existing
# instaedit-dev` BEFORE the api starts (depends_on minio-init
# condition: service_completed_successfully). The password below MUST
# match MINIO_ROOT_PASSWORD in docker-compose.local.yml — rotate both
# together if you change either one.
S3_ENDPOINT=http://minio:9000
S3_BUCKET=instaedit-dev
S3_ACCESS_KEY=instaedit_local
S3_SECRET_KEY=changeMe_instaedit_minio_dev_only_password_2025
S3_REGION=us-east-1
S3_PATH_STYLE=true

# Worker
PUBLISH_WORKER_INTERVAL_SECONDS=30
