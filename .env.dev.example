# =============================================================================
# InstaEditLogin — local-dev env template (Blocco #2.1 + P0#3 vault re-key)
# =============================================================================
# Usage:
#   cp .env.dev.example .env.dev
#   docker compose up --build
#
# The values below are SAFE for local development (MinIO + Postgres are
# only reachable on the docker network / 127.0.0.1). Operators shipping
# this file externally MUST rotate JWT_SECRET, ADMIN_INVITE_TOKEN, and
# the ENCRYPTION_KEYS entries.
#
# Conventions:
#   - One section per concern, headers with `=== ... ===`.
#   - Required-for-boot values have no default (the api fails Load()
#     with a descriptive error if unset).
#   - Defaults that match `docker-compose.yml` are commented out — set
#     them explicitly when deviating (e.g. production S3_ENDPOINT).
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Application + HTTP server
# ─────────────────────────────────────────────────────────────────────────────
APP_ENV=dev
LOG_LEVEL=info
# SERVER_HOST / SERVER_PORT removed (legacy from the Blocco #1 monolith).
# The api listens on PORT only; the host is implicit (":PORT").
PORT=8080
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ─────────────────────────────────────────────────────────────────────────────
# Database (Postgres 15 — matches docker-compose.yml's `db` service)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://instaedit:dev_password@db:5432/instaedit_login?sslmode=disable
# Equivalent individual parameters (used by cmd/migrate and a few admin tools):
# PGHOST=db
# PGPORT=5432
# PGUSER=instaedit
# PGPASSWORD=dev_password
# PGDATABASE=instaedit_login

# ─────────────────────────────────────────────────────────────────────────────
# Object storage (MinIO via docker-compose.yml's `minio` + `minio-init`
# services — P0#3 vault re-key requires S3 to be reachable at api boot)
# ─────────────────────────────────────────────────────────────────────────────
S3_ENDPOINT=http://minio:9000
S3_BUCKET=instaedit-local
S3_REGION=us-east-1
S3_PATH_STYLE=true
# Credentials MUST match MINIO_ROOT_USER / MINIO_ROOT_PASSWORD in
# docker-compose.yml (or docker-compose.local.yml's overlay). The api
# fails Load() if S3_ACCESS_KEY or S3_SECRET_KEY is empty.
S3_ACCESS_KEY=instaedit
S3_SECRET_KEY=change-this-local-secret

# ─────────────────────────────────────────────────────────────────────────────
# OAuth — Meta family (Instagram / Facebook / Threads share one app)
# ─────────────────────────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
# Redirect URIs are per-platform — the Meta OAuth server routes the
# callback to the right app variant by matching `redirect_uri` against
# the registered URIs.
INSTAGRAM_REDIRECT_URI=http://localhost:8080/api/v1/auth/instagram/callback
FACEBOOK_REDIRECT_URI=http://localhost:8080/api/v1/auth/facebook/callback
THREADS_REDIRECT_URI=http://localhost:8080/api/v1/auth/threads/callback

# ─────────────────────────────────────────────────────────────────────────────
# OAuth — TikTok
# ─────────────────────────────────────────────────────────────────────────────
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:8080/api/v1/auth/tiktok/callback

# ─────────────────────────────────────────────────────────────────────────────
# OAuth — X (Twitter) 2.0 with PKCE
# ─────────────────────────────────────────────────────────────────────────────
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:8080/api/v1/auth/twitter/callback

# ─────────────────────────────────────────────────────────────────────────────
# OAuth — YouTube (P1#6 resumable-upload tuning is below)
# ─────────────────────────────────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=https://localhost:8443/api/v1/auth/youtube/callback
# P1#6 — 16 MB is the recommended chunk for large video uploads. Must
# be a multiple of 262144 (256 KB — the YouTube resumable-upload protocol
# minimum). 16 MB balances throughput against per-chunk retry cost.
YOUTUBE_UPLOAD_CHUNK_BYTES=16777216

# ─────────────────────────────────────────────────────────────────────────────
# OAuth — Google Drive (folder import source for the async batch producer)
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=https://localhost:8443/api/v1/auth/google-drive/callback

# ─────────────────────────────────────────────────────────────────────────────
# OAuth — LinkedIn
# ─────────────────────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8080/api/v1/auth/linkedin/callback

# ─────────────────────────────────────────────────────────────────────────────
# Security — encryption + auth
# ─────────────────────────────────────────────────────────────────────────────
# Blocco #2.2 multi-key envelope. Format is a CSV of `id:base64key` pairs;
# ACTIVE_ENCRYPTION_KEY_ID selects which key signs new ciphertexts (older
# keys are retained for decrypt-only). Generate the base64 key with:
#   openssl rand -base64 32
# The legacy ENCRYPTION_KEY env var (single-key) is still accepted as a
# fallback when ENCRYPTION_KEYS is unset — prefer the multi-key form for
# any deployment that anticipates a future key rotation.
ENCRYPTION_KEYS=1:CHANGE_ME_BASE64_32_BYTES_HERE_REPLACE_BEFORE_BOOT=
ACTIVE_ENCRYPTION_KEY_ID=1
# JWT signing secret. Minimum 32 bytes enforced by internal/config. Generate with:
#   openssl rand -hex 32
JWT_SECRET=CHANGE_ME_HEX_32_BYTES_HERE_REPLACE_BEFORE_BOOT=
JWT_TTL_HOURS=24
STRICT_JWT_AUTH=true
# Gates public registration endpoints. Minimum 32 chars enforced by
# internal/config (defends against trivial brute-force if the operator
# accidentally sets a short value). Generate with:
#   openssl rand -hex 32
ADMIN_INVITE_TOKEN=CHANGE_ME_HEX_32_BYTES_HERE_REPLACE_BEFORE_BOOT=

# ─────────────────────────────────────────────────────────────────────────────
# Worker — upload pool sizing (P1#1 + P1#2 + P1#6)
# ─────────────────────────────────────────────────────────────────────────────
# `internal/worker` ingest pool size (Drive → S3 fan-in).
UPLOAD_INGEST_CONCURRENCY=3
# YouTube upload pool size (S3 → YouTube resumable fan-out). Set <=4
# until quota + RAM headroom is measured on the target VM.
YOUTUBE_UPLOAD_CONCURRENCY=4
# Legacy publish-worker poll interval — kept for the Blocco #1 path.
PUBLISH_WORKER_INTERVAL_SECONDS=1
