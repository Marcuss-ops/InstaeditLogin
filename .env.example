# ============================================
# InstaEditLogin - Environment Variables
# ============================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git!

# --- Server ---
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# --- PostgreSQL Database ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=instaedit
DB_PASSWORD=your_db_password_here
DB_NAME=instaedit_login
DB_SSLMODE=disable

# --- Meta / Facebook OAuth ---
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here
META_REDIRECT_URI=http://localhost:8080/api/v1/auth/callback

# --- AES-256 Encryption Key (32 bytes base64 encoded) ---
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your_base64_encoded_32_byte_key_here

# --- Session / JWT ---
JWT_SECRET=your_jwt_secret_here

# --- Logging ---
LOG_LEVEL=info
