[TEMPLATE]
# ============================================
# InstaEditLogin v2 — Environment Variables
# ============================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git!

# --- Server ---
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# --- Frontend SPA (optional, enables browser OAuth flow) ---
# Set to the public origin of the React/Vite app. When set, /api/v1/auth/{provider}/callback
# will 302-redirect back to {FRONTEND_URL}/auth/callback?jwt=... instead of returning JSON.
# When empty, the callback returns JSON for non-browser clients (curl, Postman).
# FRONTEND_URL=http://localhost:5173
#
# Comma-separated list of origins allowed to call the API via the browser. If empty,
# FRONTEND_URL is added automatically. Use this to allow multiple origins (dev + prod).
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com

# --- PostgreSQL Database (local or Supabase) ---
# Opzione A: DATABASE_URL (consigliata per Supabase — da Settings → Database → Connection String → URI)
# DATABASE_URL=postgresql://postgres.rfiehwbqdfrgbyavqeae:[YOUR-DB-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# Opzione B: parametri individuali (local Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USER=instaedit
DB_PASSWORD=your_db_password_here
DB_NAME=instaedit_login
DB_SSLMODE=disable

# --- Meta / Facebook + Instagram OAuth (mandatory) ---
META_APP_ID=your_meta_app_id_here
# MUST be at least 32 characters. Meta issues ~50-char hex secrets; shorter
# values usually indicate a copy/paste mistake or an unsigned placeholder and
# would be rejected by validate() at startup. Paste the value verbatim from
# developers.facebook.com → Settings → Basic → App secret.
META_APP_SECRET=your_meta_app_secret_here
META_REDIRECT_URI=http://localhost:8080/api/v1/auth/meta/callback

# Each optional platform below MUST have BOTH the client ID/KEY AND the
# CLIENT_SECRET set together — a half-configured pair (key without secret, or
# vice versa) fails startup. Each *_CLIENT_SECRET MUST be at least 32 chars.
# To disable a platform entirely, leave BOTH unset.

# --- TikTok OAuth (optional) ---
# Get credentials at https://developers.tiktok.com/
#TIKTOK_CLIENT_KEY=
#TIKTOK_CLIENT_SECRET=  # MUST be ≥32 chars if TIKTOK_CLIENT_KEY is set
#TIKTOK_REDIRECT_URI=http://localhost:8080/api/v1/auth/tiktok/callback

# --- Twitter / X OAuth (optional) ---
# Get credentials at https://developer.x.com/
#TWITTER_CLIENT_ID=
#TWITTER_CLIENT_SECRET=  # MUST be ≥32 chars if TWITTER_CLIENT_ID is set
#TWITTER_REDIRECT_URI=http://localhost:8080/api/v1/auth/twitter/callback

# --- YouTube OAuth (optional) ---
# Get credentials at https://console.cloud.google.com/
#YOUTUBE_CLIENT_ID=
#YOUTUBE_CLIENT_SECRET=  # MUST be ≥32 chars if YOUTUBE_CLIENT_ID is set
#YOUTUBE_REDIRECT_URI=http://localhost:8080/api/v1/auth/youtube/callback

# --- AES-256 Encryption Key (32 bytes base64 encoded) ---
# Must decode to EXACTLY 32 bytes for AES-256-GCM. The server rejects any other
# length at startup with an error showing both the actual and expected size
# (e.g. "got 16; expected 32"). Generate with:
#   openssl rand -base64 32
ENCRYPTION_KEY=your_base64_encoded_32_byte_key_here

# --- JWT ---
# MUST be at least 32 bytes — HS256 (RFC 7518 §3.2) requires the signing key to
# be at least as long as the hash output (256 bits = 32 bytes). The server
# refuses to start with a shorter JWT_SECRET. Generate with:
#   openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here
# Lifetime of bearer tokens issued by /api/v1/auth/{provider}/callback (default 168 = 7 days).
JWT_TTL_HOURS=168
# When STRICT_JWT_AUTH=true (default since v2): protected endpoints
# (/api/v1/posts/publish, /api/v1/accounts) require a valid
# Authorization: Bearer <jwt> header. Requests without it return 401.
#
# Set STRICT_JWT_AUTH=false ONLY during the migration rollout window when the
# JWT-aware frontend is not yet serving 100% of traffic. In legacy mode the
# handlers fall back to the user_id field on the request body/query string,
# which means anyone who knows an integer id can publish as that user.
# NEVER leave this false in production once the SPA migration is complete.
STRICT_JWT_AUTH=true

# --- Logging ---
LOG_LEVEL=info
