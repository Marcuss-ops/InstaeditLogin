[TEMPLATE]
# ============================================
# InstaEditLogin v2 — Environment Variables
# ============================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git!

# --- Server ---
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# --- Deployment Environment (mandatory for fail-fast guards) ---
# Must be one of: dev | staging | production. Default: "dev".
# See HANDOFF-LINUX.md section 12 ("Dev vs Prod database isolation") for the
# recommended per-environment topology (separate Supabase projects, separate
# DATABASE_URL, separate CORS origins, separate secret keys).
#
# SAFETY: when APP_ENV=production, the server refuses to start unless
# STRICT_JWT_AUTH=true (cmd/server/main.go fail-fast). A typo like "prod",
# "PRODUCTION", or "Production" is rejected by validate() with a list of
# the three accepted values.
APP_ENV=dev

# --- Frontend SPA (optional, enables browser OAuth flow) ---
# Set to the public origin of the React/Vite app. When set, /api/v1/auth/{provider}/callback
# will 302-redirect back to {FRONTEND_URL}/auth/callback?jwt=... instead of returning JSON.
# When empty, the callback returns JSON for non-browser clients (curl, Postman).
# FRONTEND_URL=http://localhost:5173
#
# Comma-separated list of origins allowed to call the API via the browser. If empty,
# FRONTEND_URL is added automatically. CORS origins MUST differ per environment —
# the dev SPA and the prod SPA have different hosts, and a leaky dev origin in
# prod's allowlist would let any browser-based attacker hit the prod backend
# with a stolen JWT.
#
# In .env.dev (dev SPA runs on localhost):
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173
#
# In .env.prod (prod SPA is on a public origin with HTTPS):
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://www.app.example.com
#
# Do NOT include localhost origins in .env.prod, and do NOT include the prod
# domain in .env.dev — a populated allowlist in the wrong file is a security
# regression that's easy to miss until an incident.

# --- PostgreSQL Database (local or Supabase) ---
# RECOMMENDED: use two distinct Supabase projects so dev work never touches
# production rows. See HANDOFF-LINUX.md section 12 for the full topology.
#   - instaedit-dev  : free-tier project for local development
#   - instaedit-prod : production project (paid plan, restricted access)
#
# Opzione A: DATABASE_URL (consigliata per Supabase — da Settings → Database → Connection String → URI)
# In .env.dev:    DATABASE_URL=postgresql://postgres:[DEV-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
# In .env.prod:   DATABASE_URL=postgresql://postgres:[PROD-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# Opzione B: parametri individuali (local Postgres, dev only — never used in prod)
DB_HOST=localhost
DB_PORT=5432
DB_USER=instaedit
DB_PASSWORD=your_db_password_here
DB_NAME=instaedit_login
DB_SSLMODE=disable

# --- Supabase Storage (optional — for /api/v1/storage/upload-url) ---
# When all three of SUPABASE_URL + SUPABASE_SERVICE_KEY + SUPABASE_BUCKET
# are set, the endpoint uses the Supabase Storage REST API. Otherwise it
# falls back to AWS S3 (env AWS_*) or returns 501 if neither is configured.
#
# Use one bucket per environment, matching the DATABASE_URL split:
#   DEV bucket:  instaedit-dev-uploads    (free tier, public read)
#   PROD bucket: instaedit-prod-uploads   (paid plan, public read for social
#                                          platforms to fetch media_url)
#
# SECURITY: SUPABASE_SERVICE_KEY is the service-role JWT (bypasses RLS).
# Never expose it to the browser. Rotate immediately if leaked.
#
# In .env.dev:
# SUPABASE_URL=https://abcdefghijklmnopqrst.supabase.co
# SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.<DEV-SERVICE-KEY>
# SUPABASE_BUCKET=instaedit-dev-uploads
#
# In .env.prod:
# SUPABASE_URL=https://abcdefghijklmnopqrst.supabase.co
# SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.<PROD-SERVICE-KEY>
# SUPABASE_BUCKET=instaedit-prod-uploads
#
# NAMING TIP (for secret managers like 1Password / k8s secrets / Vault):
# Use _DEV_KEY / _PROD_KEY suffixes so a single secret ID distinguishes
# the environments at a glance. The .env file uses the unsuffixed
# SUPABASE_SERVICE_KEY (the backend reads one var); the suffix lives only
# in your secret store.
#   secret: 1P: InstaeditLogin / Supabase Service Key / DEV   → .env.dev
#   secret: 1P: InstaeditLogin / Supabase Service Key / PROD  → .env.prod

# --- Meta / Facebook + Instagram OAuth (mandatory) ---
META_APP_ID=your_meta_app_id_here
# MUST be at least 32 characters. Meta issues ~50-char hex secrets; shorter
# values usually indicate a copy/paste mistake or an unsigned placeholder and
# would be rejected by validate() at startup. Paste the value verbatim from
# developers.facebook.com → Settings → Basic → App secret.
META_APP_SECRET=your_meta_app_secret_here
META_REDIRECT_URI=http://localhost:8080/api/v1/auth/meta/callback

# Each optional platform below MUST have BOTH the client ID/KEY AND the
# CLIENT_SECRET set together — a half-configured pair (key without secret, or
# vice versa) fails startup. Each *_CLIENT_SECRET MUST be at least 32 chars.
# To disable a platform entirely, leave BOTH unset.

# --- TikTok OAuth (optional) ---
# Get credentials at https://developers.tiktok.com/
#
# IMPORTANT: while the app is in Sandbox mode, only TikTok accounts added as
# "Target Users" in the Developer Portal can complete the OAuth flow. If a
# non-whitelisted account tries to log in, TikTok returns the error
# "non_sandbox_target". Add the test account under Sandbox → Target Users and
# wait up to 60 minutes for propagation.
#
# Make sure TIKTOK_REDIRECT_URI matches EXACTLY the redirect URI registered in
# the TikTok Developer Portal (protocol, host, path and trailing slash).
#TIKTOK_CLIENT_KEY=
#TIKTOK_CLIENT_SECRET=  # MUST be ≥32 chars if TIKTOK_CLIENT_KEY is set
#TIKTOK_REDIRECT_URI=http://localhost:8080/api/v1/auth/tiktok/callback

# --- Twitter / X OAuth (optional) ---
# Get credentials at https://developer.x.com/
#TWITTER_CLIENT_ID=
#TWITTER_CLIENT_SECRET=  # MUST be ≥32 chars if TWITTER_CLIENT_ID is set
#TWITTER_REDIRECT_URI=http://localhost:8080/api/v1/auth/twitter/callback

# --- YouTube OAuth (optional) ---
# Get credentials at https://console.cloud.google.com/
#YOUTUBE_CLIENT_ID=
#YOUTUBE_CLIENT_SECRET=  # MUST be ≥32 chars if YOUTUBE_CLIENT_ID is set
#YOUTUBE_REDIRECT_URI=http://localhost:8080/api/v1/auth/youtube/callback

# --- AES-256 Encryption Key (32 bytes base64 encoded) ---
# Must decode to EXACTLY 32 bytes for AES-256-GCM. The server rejects any other
# length at startup with an error showing both the actual and expected size
# (e.g. "got 16; expected 32"). Generate with:
#   openssl rand -base64 32
ENCRYPTION_KEY=your_base64_encoded_32_byte_key_here

# --- JWT ---
# MUST be at least 32 bytes — HS256 (RFC 7518 §3.2) requires the signing key to
# be at least as long as the hash output (256 bits = 32 bytes). The server
# refuses to start with a shorter JWT_SECRET. Generate with:
#   openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here
# Lifetime of bearer tokens issued by /api/v1/auth/{provider}/callback (default 168 = 7 days).
JWT_TTL_HOURS=168
# When STRICT_JWT_AUTH=true (default since v2): protected endpoints
# (/api/v1/posts/publish, /api/v1/accounts) require a valid
# Authorization: Bearer <jwt> header. Requests without it return 401.
#
# Set STRICT_JWT_AUTH=false ONLY during the migration rollout window when the
# JWT-aware frontend is not yet serving 100% of traffic. In legacy mode the
# handlers fall back to the user_id field on the request body/query string,
# which means anyone who knows an integer id can publish as that user.
# NEVER leave this false in production once the SPA migration is complete.
STRICT_JWT_AUTH=true

# --- Logging ---
LOG_LEVEL=info
