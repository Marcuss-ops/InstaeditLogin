[TEMPLATE]
# ============================================
# InstaEditLogin v2 — Environment Variables
# ============================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git!

# --- Server ---
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# --- PostgreSQL Database (local or Supabase) ---
# Local Postgres:
DB_HOST=localhost
DB_PORT=5432
DB_USER=instaedit
DB_PASSWORD=your_db_password_here
DB_NAME=instaedit_login
DB_SSLMODE=disable

# Per usare Supabase Postgres (dal dashboard Supabase → Project → Settings → Database → Connection String):
# DB_HOST=aws-0-eu-west-1.pooler.supabase.com
# DB_PORT=6543
# DB_USER=postgres.yourproject
# DB_PASSWORD=your_supabase_db_password
# DB_NAME=postgres
# DB_SSLMODE=require

# --- Meta / Facebook + Instagram OAuth (mandatory) ---
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here
META_REDIRECT_URI=http://localhost:8080/api/v1/auth/meta/callback

# --- TikTok OAuth (optional) ---
# Get credentials at https://developers.tiktok.com/
#TIKTOK_CLIENT_KEY=
#TIKTOK_CLIENT_SECRET=
#TIKTOK_REDIRECT_URI=http://localhost:8080/api/v1/auth/tiktok/callback

# --- Twitter / X OAuth (optional) ---
# Get credentials at https://developer.x.com/
#TWITTER_CLIENT_ID=
#TWITTER_CLIENT_SECRET=
#TWITTER_REDIRECT_URI=http://localhost:8080/api/v1/auth/twitter/callback

# --- YouTube OAuth (optional) ---
# Get credentials at https://console.cloud.google.com/
#YOUTUBE_CLIENT_ID=
#YOUTUBE_CLIENT_SECRET=
#YOUTUBE_REDIRECT_URI=http://localhost:8080/api/v1/auth/youtube/callback

# --- AES-256 Encryption Key (32 bytes base64 encoded) ---
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your_base64_encoded_32_byte_key_here

# --- JWT ---
JWT_SECRET=your_jwt_secret_here

# --- Logging ---
LOG_LEVEL=info
