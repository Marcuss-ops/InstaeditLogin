# InstaEditLogin — Production Environment
# Copy to .env.prod and fill in real secrets from your secret manager.
# NEVER commit this file with real values.

APP_ENV=production
LOG_LEVEL=warn

# Server
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
FRONTEND_URL=https://app.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com,https://www.app.example.com

# Database (managed Postgres / Supabase)
DATABASE_URL=postgresql://postgres:PROD_PASSWORD@PROD_HOST:6543/postgres?sslmode=require

# Meta (mandatory)
META_APP_ID=your_prod_meta_app_id
META_APP_SECRET=your_prod_meta_app_secret_at_least_32_chars
META_REDIRECT_URI=https://api.example.com/api/v1/auth/meta/callback

# Optional OAuth providers
#TIKTOK_CLIENT_KEY=
#TIKTOK_CLIENT_SECRET=
#TIKTOK_REDIRECT_URI=https://api.example.com/api/v1/auth/tiktok/callback

#TWITTER_CLIENT_ID=
#TWITTER_CLIENT_SECRET=
#TWITTER_REDIRECT_URI=https://api.example.com/api/v1/auth/twitter/callback

#YOUTUBE_CLIENT_ID=
#YOUTUBE_CLIENT_SECRET=
#YOUTUBE_REDIRECT_URI=https://api.example.com/api/v1/auth/youtube/callback

#LINKEDIN_CLIENT_ID=
#LINKEDIN_CLIENT_SECRET=
#LINKEDIN_REDIRECT_URI=https://api.example.com/api/v1/auth/linkedin/callback

# Security — generate strong random secrets, rotate regularly
# openssl rand -base64 32
ENCRYPTION_KEY=your_prod_base64_encoded_32_byte_key_here
# openssl rand -hex 32
JWT_SECRET=your_prod_jwt_secret_here_at_least_32_bytes
JWT_TTL_HOURS=168
STRICT_JWT_AUTH=true

# Storage (Supabase recommended)

# Worker
PUBLISH_WORKER_INTERVAL_SECONDS=30
