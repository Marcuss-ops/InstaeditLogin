# InstaEditLogin — Test Environment
# Used by CI and local test runs. Copy to .env.test and fill in real secrets.

APP_ENV=dev
LOG_LEVEL=error

# Server
SERVER_PORT=8081
SERVER_HOST=127.0.0.1
FRONTEND_URL=
CORS_ALLOWED_ORIGINS=

# Database (dedicated test database, can be ephemeral)
DATABASE_URL=postgresql://instaedit:test_password@localhost:5432/instaedit_login_test?sslmode=disable

# Meta (mandatory — use test app credentials)
META_APP_ID=test_meta_app_id
META_APP_SECRET=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
META_REDIRECT_URI=http://localhost:8081/api/v1/auth/meta/callback

# Optional OAuth providers — leave empty to disable
#TIKTOK_CLIENT_KEY=
#TIKTOK_CLIENT_SECRET=
#TIKTOK_REDIRECT_URI=http://localhost:8081/api/v1/auth/tiktok/callback

#TWITTER_CLIENT_ID=
#TWITTER_CLIENT_SECRET=
#TWITTER_REDIRECT_URI=http://localhost:8081/api/v1/auth/twitter/callback

#YOUTUBE_CLIENT_ID=
#YOUTUBE_CLIENT_SECRET=
#YOUTUBE_REDIRECT_URI=http://localhost:8081/api/v1/auth/youtube/callback

#LINKEDIN_CLIENT_ID=
#LINKEDIN_CLIENT_SECRET=
#LINKEDIN_REDIRECT_URI=http://localhost:8081/api/v1/auth/linkedin/callback

# Security — use deterministic test secrets only in test environment
ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
JWT_SECRET=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
JWT_TTL_HOURS=1
STRICT_JWT_AUTH=true

# Storage disabled in tests unless explicitly testing upload-url

# Worker
PUBLISH_WORKER_INTERVAL_SECONDS=5

# --- Velox integration ---
# Base URL of the Velox master (internal/private, e.g. http://velox-master:8080).
# The InstaEdit BFF uses this to forward user-facing Velox requests.
VELOX_CONTROL_URL=

# Shared HS256 secret for the short-lived InstaEdit → Velox control JWT.
# MUST be at least 32 bytes and identical to Velox's INSTAEDIT_CONTROL_JWT_SECRET.
VELOX_CONTROL_JWT_SECRET=

# Server-to-server token Velox sends when calling InstaEdit /internal/v1/* callbacks.
# MUST match the value configured in Velox as SOCIAL_API_TOKEN.
VELOX_API_TOKEN=

# HMAC-SHA256 secret used to verify Velox webhook signatures.
# Distinct from VELOX_API_TOKEN.
VELOX_WEBHOOK_SECRET=

