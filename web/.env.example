# ============================================
# SocialSync Frontend — Environment Variables
# ============================================
# Copy to .env and fill in your Supabase project values.

# Supabase Project URL (from https://app.supabase.com → Project → Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key (public, safe for frontend)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API base URL (your Go server)
VITE_API_BASE_URL=http://localhost:8080
