# ============================================
# SocialSync Frontend — Environment Variables
# ============================================
# Copy to .env and fill in your Supabase project values.

# Supabase Project URL (dal dashboard Supabase → Settings → API)
VITE_SUPABASE_URL=https://abcdefghijklmnopqrst.supabase.co

# Supabase Anon Key (pubblico, sicuro per il frontend — da Settings → API)
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Backend API base URL (URL del server Go deployato su Railway/Render/Fly)
# Per sviluppo locale: http://localhost:8080
VITE_API_BASE_URL=https://api.instaedit.org

# ============================================
# Backend — OAuth Provider Credentials
# ============================================
# Da copiare nel .env della root (InstaeditLogin/.env), non in web/.env
#
# TikTok (developers.tiktok.com → Manage Apps)
# TIKTOK_CLIENT_KEY=your_client_key
# TIKTOK_CLIENT_SECRET=your_client_secret
# TIKTOK_REDIRECT_URI=https://instaedit.org/api/v1/auth/tiktok/callback
#
# Twitter/X (developer.x.com → Projects & Apps)
# TWITTER_CLIENT_ID=your_client_id
# TWITTER_CLIENT_SECRET=your_client_secret
# TWITTER_REDIRECT_URI=https://instaedit.org/api/v1/auth/twitter/callback
#
# YouTube/Google (console.cloud.google.com → APIs & Services)
# YOUTUBE_CLIENT_ID=your_client_id
# YOUTUBE_CLIENT_SECRET=your_client_secret
# YOUTUBE_REDIRECT_URI=https://instaedit.org/api/v1/auth/youtube/callback
