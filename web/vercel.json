{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm ci",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "instaedit.org" }],
      "destination": "https://app.instaedit.org/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        { "type": "host", "value": "www.instaedit.org" }
      ],
      "destination": "https://app.instaedit.org/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
